#remote-cert-tls server                                                                          
persist-key                                                                                      
persist-tun                                                                                      
verb 4                                                                                           
#comp-lzo                                                                                         
#log-append /var/log/openvpn-colo.log                                                            
cipher AES-256-CBC
auth SHA256                                                                                                
#tuning for problems                                                                             
tcp-queue-limit 256                                                                              
bcast-buffers 4096  
